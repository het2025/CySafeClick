# ============================================
# VAJRA — Root .gitignore (Monorepo)
# ============================================

# ─── Dependency directories ─────────────────
node_modules/
**/node_modules/

# ─── Build outputs ──────────────────────────
dist/
**/dist/
.angular/
**/.angular/

# ─── Environment variables (NEVER commit) ───
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# ─── OS / System files ──────────────────────
desktop.ini
**/desktop.ini
Thumbs.db
.DS_Store

# ─── Logs ───────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
logs/

# ─── IDEs ───────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Temp / Scratch files ───────────────────
task.txt
*.tmp

# ─── Package lock (optional - keep if you want reproducible installs) ───
# package-lock.json  ← KEEP this, it helps reproducibility
