# ============================================
# CySafeClick — Root .gitignore (Monorepo)
# ============================================

# ─── Dependency directories ─────────────────
node_modules/
**/node_modules/

# ─── Build outputs ──────────────────────────
dist/
**/dist/
.angular/
**/.angular/

# ─── TypeScript build cache ─────────────────
*.tsbuildinfo
**/*.tsbuildinfo

# ─── Test coverage & reports ────────────────
coverage/
**/coverage/
.nyc_output/
test-results/

# ─── Cache directories ───────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ─── Environment variables (NEVER commit) ───
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# ─── OS / System files ──────────────────────
desktop.ini
**/desktop.ini
Thumbs.db
.DS_Store

# ─── Logs ───────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
logs/

# ─── IDEs ───────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Temp / Scratch files ───────────────────
task.txt
*.tmp
*.bak
*.swp
*~

# ─── Screenshots (dev testing artifacts) ────
# Comment out next line if you want to keep screenshots in repo
Screenshot*.png
Screenshot*.jpg

# ─── Package lock (optional - keep if you want reproducible installs) ───
# package-lock.json  ← KEEP this, it helps reproducibility
