{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "static-api-data",
      "urls": [
        "/api/tips",
        "/api/stories",
        "/api/glossary",
        "/api/platforms/2fa"
      ],
      "cacheConfig": {
        "maxSize": 10,
        "maxAge": "7d",
        "timeout": "10s",
        "strategy": "performance"
      }
    },
    {
      "name": "threat-feed",
      "urls": [
        "/api/threats/feed"
      ],
      "cacheConfig": {
        "maxSize": 5,
        "maxAge": "1h",
        "timeout": "3s",
        "strategy": "freshness"
      }
    },
    {
      "name": "scam-alerts",
      "urls": [
        "/api/alerts"
      ],
      "cacheConfig": {
        "maxSize": 5,
        "maxAge": "30m",
        "timeout": "10s",
        "strategy": "freshness"
      }
    },
    {
      "name": "translations",
      "urls": [
        "/assets/i18n/*.json"
      ],
      "cacheConfig": {
        "maxSize": 20,
        "maxAge": "30d",
        "timeout": "5s",
        "strategy": "performance"
      }
    }
  ]
}
