# ============================================
# SafeClick Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# MongoDB Connection URL
# For local MongoDB:   mongodb://localhost:27017/safeclick
# For MongoDB Atlas:   mongodb+srv://<username>:<password>@<cluster>.mongodb.net/safeclick
MONGO_URI=mongodb://localhost:27017/safeclick

# Server Port
PORT=3000

# Node Environment (development | production)
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:4200

# Groq API Key (for AI features using Llama 3)
# Get your FREE key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
